# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# LLM Configuration
# Primary: Groq (free tier at console.groq.com)
GROQ_API_KEY=your-groq-api-key-here

# Fallback: Ollama (local, run `ollama serve` first)
OLLAMA_BASE_URL=http://localhost:11434

# Which LLM provider to use: "groq" or "ollama"
LLM_PROVIDER=groq

# Groq model to use (llama-3.1-8b-instant is fast and free)
GROQ_MODEL=llama-3.1-8b-instant

# Ollama model to use (must be pulled first with `ollama pull`)
OLLAMA_MODEL=llama3.1:8b
